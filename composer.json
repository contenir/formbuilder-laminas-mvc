{
    "name": "contenir/formbuilder-laminas-mvc",
    "description": "Laminas MVC adapter for contenir/formbuilder — Laminas\\Db loader, view helper, submit controller, Module + ConfigProvider.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1 || ^8.2 || ^8.3",
        "contenir/formbuilder": "^0.1.1",
        "laminas/laminas-db": "^2.17",
        "laminas/laminas-form": "^3.20",
        "laminas/laminas-mail": "^2.22",
        "laminas/laminas-mvc": "^3.4",
        "laminas/laminas-servicemanager": "^3.0",
        "laminas/laminas-session": "^2.16",
        "laminas/laminas-view": "^2.30",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "laminas/laminas-i18n": "^2.32",
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": { "Contenir\\FormBuilder\\Laminas\\Mvc\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Contenir\\FormBuilder\\Laminas\\Mvc\\Tests\\": "tests/" }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../formbuilder",
            "canonical": false,
            "options": {
                "symlink": true
            }
        },
        {
            "type": "vcs",
            "url": "https://github.com/contenir/formbuilder",
            "no-api": true
        }
    ],
    "extra": {
        "laminas": {
            "module": "Contenir\\FormBuilder\\Laminas\\Mvc"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs": "phpcs",
        "cs-fix": "phpcbf"
    },
    "config": {
        "sort-packages": true
    }
}
